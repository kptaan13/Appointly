# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/appointment_booking_db

# JWT Secrets (use long random strings in production)
ACCESS_TOKEN_SECRET=your-access-token-secret-min-16-chars
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-16-chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
CLIENT_ORIGIN=http://localhost:5173

# Email (leave blank in dev to use Ethereal auto-account)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@appointmentbooking.dev
